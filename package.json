{
  "name": "ai-shorts-creator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "desktop": "concurrently \"tsx server.ts\" \"wait-on http://localhost:3000 && electron .\"",
    "electron": "electron .",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.2.0",
    "@types/node-ssh": "^7.0.6",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "node-ssh": "^13.2.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.0.0",
    "electron": "^36.9.5",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.parabolasyrc.shorts-creator",
    "productName": "AI Shorts Creator",
    "files": [
      "dist/**/*",
      "main.cjs",
      "public/**/*",
      "export.py",
      "transcribe.py",
      ".env"
    ],
    "directories": {
      "output": "release"
    },
    "asar": false,
    "win": {
      "target": "nsis",
      "icon": "public/favicon.png"
    }
  }
}
